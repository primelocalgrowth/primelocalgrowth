# Resend (Email notifications)
# Get from: https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxx

# Beehiiv (Newsletter + subscriber automation)
# Get API key from: https://dashboard.beehiiv.com/settings/integrations
# Get publication ID from: https://dashboard.beehiiv.com/publications (look for pub_xxxxx)
BEEHIIV_API_KEY=pak_xxxxxxxxxxxxxxxxxxxxx
BEEHIIV_PUBLICATION_ID=pub_xxxxxxxxxxxxxxxxxxxxx

# Google Sheets (Lead database)
# This is the webhook URL from Google Apps Script
# Deploy the script from: prime-local-growth/google-apps-script/sheets-webhook.gs
# Deploy as Web App and get the URL
GOOGLE_SHEETS_WEBHOOK_URL=https://script.google.com/macros/d/SCRIPT_ID/userweb...
