# REQUIRED: Google Sheets lead database
# Production Apps Script Web App URL. The website treats this as the durable lead record.
GOOGLE_SHEETS_WEBHOOK_URL=https://script.google.com/macros/s/SCRIPT_ID/exec

# RECOMMENDED: Resend transactional email
# Used for Adam's lead alert, the requested audit confirmation, and paid onboarding.
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxx

# OPTIONAL: Google Apps Script audit-document workflow
# Keep separate from GOOGLE_SHEETS_WEBHOOK_URL only when it performs document generation.
MASTER_APPS_SCRIPT_WEBHOOK_URL=https://script.google.com/macros/s/SCRIPT_ID/exec

# OPTIONAL: Beehiiv newsletter and explicitly opted-in marketing only
# Audit leads and paying clients are not subscribed unless they separately consent.
BEEHIIV_API_KEY=pak_xxxxxxxxxxxxxxxxxxxxx
BEEHIIV_PUBLICATION_ID=pub_xxxxxxxxxxxxxxxxxxxxx

# OPTIONAL: Stripe invoice/checkout onboarding
STRIPE_SECRET_KEY=sk_xxxxxxxxxxxxxxxxxxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxxx
STRIPE_GEO_PRICE_ID=price_xxxxxxxxxxxxxxxxxxxxx
